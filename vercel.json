{
  "version": 2,
  "name": "mediconnect-monorepo",
  "builds": [
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/ai/(.*)",
      "destination": "frontend/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "backend/src/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
